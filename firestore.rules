rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdminOrDev() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          currentUserData().isAdmin == true ||
          currentUserData().isDev == true
        );
    }

    function ownsExistingDocByOwnerUid() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncomingDocByOwnerUid() {
      return isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function ownsExistingDocByUserId() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocByUserId() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsExistingDocByUid() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function ownsIncomingDocByUid() {
      return isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    function isTradingOfferParticipant() {
      return isSignedIn()
        && (
          resource.data.senderUid == request.auth.uid ||
          resource.data.receiverUid == request.auth.uid
        );
    }

    function isIncomingTradingOfferSender() {
      return isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.receiverUid != request.auth.uid;
    }

    function isTradingSessionParticipant() {
      return isSignedIn()
        && (
          resource.data.traderOneUid == request.auth.uid ||
          resource.data.traderTwoUid == request.auth.uid
        );
    }

    function isIncomingTradingSessionParticipant() {
      return isSignedIn()
        && request.resource.data.traderOneUid != request.resource.data.traderTwoUid
        && (
          request.resource.data.traderOneUid == request.auth.uid ||
          request.resource.data.traderTwoUid == request.auth.uid
        );
    }

    function isMatchInviteParticipant() {
      return isSignedIn()
        && (
          resource.data.senderUid == request.auth.uid ||
          resource.data.recipientUid == request.auth.uid
        );
    }

    function isIncomingMatchInviteSender() {
      return isSignedIn()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid != request.auth.uid;
    }

    function isNotificationTarget() {
      return isSignedIn() && resource.data.targetUid == request.auth.uid;
    }

    function isIncomingNotificationActor() {
      return isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.targetUid != '';
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId);

      match /arc_blueprints/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /arc_blueprint_targets/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /arc_scrappy_items/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /trading_activity/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /notification_tokens/{tokenId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /usage_counters/{periodId} {
        allow read: if isOwner(userId) || isAdminOrDev();
        allow create, update: if isOwner(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.periodKey == periodId;
        allow delete: if isAdminOrDev();
      }

      match /subscription_events/{eventId} {
        allow read: if isOwner(userId) || isAdminOrDev();
        allow write: if false;
      }

      match /referral_wallet/{walletDocId} {
        allow read: if isOwner(userId) || isAdminOrDev();
        allow write: if false;
      }

      match /{document=**} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /arc_blueprint_drop_reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdminOrDev();
    }

    match /arc_blueprint_demand/{blueprintId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdminOrDev();
    }

    match /arc_trader_profiles/{profileUid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUid) || ownsIncomingDocByUid() || ownsIncomingDocByUserId();
      allow delete: if isOwner(profileUid) || ownsExistingDocByUid() || ownsExistingDocByUserId();
    }

    match /arc_trader_availability/{profileUid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUid) || ownsIncomingDocByUid() || ownsIncomingDocByUserId();
      allow delete: if isOwner(profileUid) || ownsExistingDocByUid() || ownsExistingDocByUserId();
    }

    match /arc_trader_away/{profileUid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUid) || ownsIncomingDocByUid() || ownsIncomingDocByUserId();
      allow delete: if isOwner(profileUid) || ownsExistingDocByUid() || ownsExistingDocByUserId();
    }

    match /trading_listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if ownsIncomingDocByOwnerUid()
        && request.resource.data.id == listingId
        && request.resource.data.active == true;
      allow update: if ownsExistingDocByOwnerUid()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.id == resource.data.id;
      allow delete: if ownsExistingDocByOwnerUid();
    }

    match /trading_offers/{offerId} {
      allow read: if isTradingOfferParticipant();
      allow create: if isIncomingTradingOfferSender()
        && request.resource.data.id == offerId;
      allow update: if isTradingOfferParticipant()
        && request.resource.data.id == resource.data.id
        && request.resource.data.listingId == resource.data.listingId
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.receiverUid == resource.data.receiverUid;
      allow delete: if false;
    }

    match /trading_sessions/{sessionId} {
      allow read: if isTradingSessionParticipant();
      allow create: if isIncomingTradingSessionParticipant()
        && request.resource.data.id == sessionId;
      allow update: if isTradingSessionParticipant()
        && request.resource.data.id == resource.data.id
        && request.resource.data.traderOneUid == resource.data.traderOneUid
        && request.resource.data.traderTwoUid == resource.data.traderTwoUid;
      allow delete: if false;
    }

    match /trading_notifications/{notificationId} {
      allow read: if isNotificationTarget();
      allow create: if isIncomingNotificationActor()
        && request.resource.data.id == notificationId;
      allow update: if isNotificationTarget()
        && request.resource.data.id == resource.data.id
        && request.resource.data.targetUid == resource.data.targetUid
        && request.resource.data.actorUid == resource.data.actorUid;
      allow delete: if isNotificationTarget();
    }

    match /arc_match_rider_profiles/{profileUid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUid)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(profileUid);
    }

    match /arc_match_rider_invites/{inviteId} {
      allow read: if isMatchInviteParticipant();
      allow create: if isIncomingMatchInviteSender()
        && request.resource.data.id == inviteId;
      allow update: if isMatchInviteParticipant()
        && request.resource.data.id == resource.data.id
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.recipientUid == resource.data.recipientUid;
      allow delete: if false;
    }

    match /arc_trade_listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if ownsIncomingDocByUserId()
        && request.resource.data.id == listingId;
      allow update: if ownsExistingDocByUserId()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.id == resource.data.id;
      allow delete: if ownsExistingDocByUserId();
    }

    match /arc_trade_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && (
          request.resource.data.traderOneUid == request.auth.uid ||
          request.resource.data.traderTwoUid == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.ownerUid == request.auth.uid
        );
      allow update: if isSignedIn()
        && (
          resource.data.traderOneUid == request.auth.uid ||
          resource.data.traderTwoUid == request.auth.uid ||
          resource.data.userId == request.auth.uid ||
          resource.data.ownerUid == request.auth.uid
        );
      allow delete: if false;
    }

    match /beta_feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn()
        && (
          resource.data.uid == request.auth.uid ||
          isAdminOrDev()
        );
      allow update: if isAdminOrDev();
      allow delete: if false;

      match /replies/{replyId} {
        allow read: if isSignedIn()
          && (
            get(/databases/$(database)/documents/beta_feedback/$(feedbackId)).data.uid == request.auth.uid ||
            isAdminOrDev()
          );
        allow create: if isSignedIn()
          && (
            isAdminOrDev() ||
            get(/databases/$(database)/documents/beta_feedback/$(feedbackId)).data.uid == request.auth.uid
          );
        allow update, delete: if false;
      }
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrDev();
      allow delete: if false;
    }

    match /monetisation_config/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isAdminOrDev();
      allow delete: if false;
    }

    match /system_counters/{counterId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && counterId == 'arc_trader_ids'
        && request.resource.data.lastIssuedNumber is int
        && request.resource.data.lastIssuedNumber >= 0
        && request.resource.data.lastIssuedNumber <= 400000000;
      allow delete: if false;
    }

    match /referral_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.code == code
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if false;
    }

    match /referral_events/{eventId} {
      allow read: if isAdminOrDev()
        || (isSignedIn() && resource.data.referrerUid == request.auth.uid)
        || (isSignedIn() && resource.data.referredUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /payout_requests/{requestId} {
      allow read: if isAdminOrDev()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amountPence is int
        && request.resource.data.amountPence >= 2500;
      allow update: if isAdminOrDev();
      allow delete: if false;
    }

    match /stripe_customers/{uid} {
      allow read: if isOwner(uid) || isAdminOrDev();
      allow write: if false;
    }

    match /uag_ids/{uagId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.uagId == uagId;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.uagId == resource.data.uagId;
      allow delete: if false;
    }

    match /public_profiles/{profileUid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(profileUid) || ownsIncomingDocByUid() || ownsIncomingDocByUserId();
      allow delete: if isOwner(profileUid) || ownsExistingDocByUid() || ownsExistingDocByUserId();
    }

    match /dose_tasks/{taskId} {
      allow read, create, update, delete: if isSignedIn()
        && (
          request.resource.data.uid == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          resource.data.userId == request.auth.uid
        );
    }

    match /wall_of_legends/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminOrDev();
    }
  }
}
