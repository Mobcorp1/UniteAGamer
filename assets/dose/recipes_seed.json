        {
          "name": "Micro-scale or measuring spoons",
          "notes": "agar is sensitive to dose"
        }
      ],
      "steps": [
        {
          "order": 1,
          "instruction": "Add water to a saucepan. Whisk in agar while cold to prevent clumping."
        },
        {
          "order": 2,
          "instruction": "Bring to a boil, then simmer 2 minutes, whisking often (agar needs a proper boil)."
        },
        {
          "order": 3,
          "instruction": "Turn heat low. Whisk in honey, salt, chilli flakes, and lime zest."
        },
        {
          "order": 4,
          "instruction": "Remove from heat. Let it cool 30–60 seconds, then whisk in lime juice."
        },
        {
          "order": 5,
          "instruction": "Pour into moulds. Chill until fully set (about 60 minutes)."
        },
        {
          "order": 6,
          "instruction": "Pop out and store chilled. If using a tray, slice into bite-sized cubes."
        }
